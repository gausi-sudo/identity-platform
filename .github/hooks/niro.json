{
  "version": 1,
  "hooks": {
    "postToolUse": [
      {
        "type": "command",
        "command": "niro hook --event=post-tool-use --agent=copilot",
        "timeoutSec": 30
      }
    ],
    "agentStop": [
      {
        "type": "command",
        "command": "niro hook --event=agent-stop --agent=copilot",
        "timeoutSec": 10
      }
    ]
  }
}
